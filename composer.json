{
    "name": "fab2s/dt0",
    "description": "Immutable DTOs with bidirectional casting. No framework required. 8x faster than the alternative.",
    "type": "library",
    "authors": [{
        "name": "Fabrice de Stefanis"
    }],
    "homepage": "https://github.com/fab2s/dt0",
    "support": {
        "issues": "https://github.com/fab2s/dt0/issues",
        "source": "https://github.com/fab2s/dt0"
    },
    "keywords": [
        "Data-Transfer-Object",
        "DTO",
        "DT0",
        "Symfony",
        "Laravel",
        "PHP",
        "Serializable",
        "immutable",
        "readonly",
        "JSON",
        "Data-Processing",
        "php8",
        "value-object"
    ],
    "license": [
        "MIT"
    ],
    "require": {
        "php": "^8.1",
        "ext-zlib": "*",
        "fab2s/context-exception": "^2.0|^3.0",
        "fab2s/enumerate": "^0.0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "laravel/pint": "^1.21.2",
        "orchestra/testbench": "^9.0|^10.0",
        "illuminate/translation": "^11.0|^12.0",
        "illuminate/validation": "^11.0|^12.0",
        "nesbot/carbon": "^2.62|^3.0",
        "fab2s/math": "^2.0",
        "spatie/laravel-data": "^4.19",
        "phpstan/phpstan": "^2.1"
    },
    "suggest": {
        "fab2s/laravel-dt0": "To use Dt0 in Laravel (the awesome) with full validation and attribute casting",
        "fab2s/Math": "v2.x To cast any Dt0 property in arbitrary base ten decimals",
        "nesbot/carbon": "To use CarbonCaster and handle both Carbon and CarbonImmutable casts"
    },
    "autoload": {
        "psr-4": {
            "fab2s\\Dt0\\": "src"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "rm -rf .*.cache"
        ],
        "post-install-cmd": [
            "rm -rf .*.cache"
        ],
        "fix": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/pint --ansi --config pint.json --"
        ],
        "test": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/phpunit --colors --"
        ],
        "cov": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/phpunit --colors --coverage-html ./cov --"
        ],
        "stan": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/phpstan analyse -c ./phpstan.neon --ansi --"
        ],
        "stan-tests": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/phpstan analyse -c ./phpstan-tests.neon --ansi --"
        ]
    }
}
